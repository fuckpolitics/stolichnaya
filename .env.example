# Базовый путь (для GitHub Pages проектного сайта).
# Для локальной разработки не задавайте — будет '/'.
# Для деплоя задаётся в .github/workflows/deploy.yml.
# VITE_BASE_PATH=/stolichnaya/

# CMS-панель (/admin)
# VITE_ADMIN_PIN      — PIN-код для входа в CMS (по умолчанию: admin)
# VITE_GITHUB_OWNER   — логин владельца репозитория на GitHub (например: fuckpolitics)
# VITE_GITHUB_REPO    — название репозитория (например: stolichnaya)
# VITE_GITHUB_TOKEN   — Personal Access Token (fine-grained, rights: contents: write).
#                       Если задан, поле ввода токена в CMS не показывается.
# Для деплоя добавьте эти переменные в Settings → Secrets → Actions
VITE_ADMIN_PIN=admin
VITE_GITHUB_OWNER=fuckpolitics
VITE_GITHUB_REPO=stolichnaya
VITE_GITHUB_TOKEN=
